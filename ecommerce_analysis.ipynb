   "source": [
    "# 电商销售数据分析\n",
    "\n",
    "## 分析目标\n",
    "- 理解销售整体状况\n",
    "- 识别高价值用户\n",
    "- 发现畅销品类\n",
    "- 分析物流时效"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "print(\"库导入成功\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('data/ecommerce_data.csv')\n",
    "print(f\"数据集形状: {df.shape}\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df['total_amount'] = df['quantity'] * df['unit_price'] * (1 - df['discount']) + df['shipping_cost']\n",
    "df['order_date'] = pd.to_datetime(df['order_date'])\n",
    "\n",
    "print(f\"总销售额: ${df['total_amount'].sum():,.2f}\")\n",
    "print(f\"平均订单金额: ${df['total_amount'].mean():,.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "category_sales = df.groupby('product_category')['total_amount'].sum().sort_values(ascending=False)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "category_sales.plot(kind='bar', color='steelblue')\n",
    "plt.title('各品类销售额分布', fontsize=14)\n",
    "plt.xlabel('商品类别')\n",
    "plt.ylabel('销售额($)')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"畅销品类 Top 3:\")\n",
    "print(category_sales.head(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rfm = df.groupby('customer_id').agg({\n",
    "    'order_date': lambda x: (pd.Timestamp('2024-01-31') - x.max()).days,\n",
    "    'order_id': 'count',\n",
    "    'total_amount': 'sum'\n",
    "}).rename(columns={'order_date': 'recency', 'order_id': 'frequency', 'total_amount': 'monetary'})\n",
    "\n",
    "high_value = rfm[rfm['monetary'] > rfm['monetary'].quantile(0.75)]\n",
    "print(f\"高价值用户数量: {len(high_value)}\")\n",
    "print(f\"高价值用户贡献占比: {high_value['monetary'].sum() / rfm['monetary'].sum() * 100:.1f}%\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "payment_stats = df.groupby('payment_method')['total_amount'].sum()\n",
    "\n",
